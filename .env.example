# Database (Neon/Supabase Postgres connection string)
DATABASE_URL="postgresql://user:password@host:5432/novacrm?schema=public"

# Auth.js
AUTH_SECRET="" # generate with `npx auth secret`
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# Stripe billing — create these Products/Prices in your Stripe dashboard first
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# AI CRM Builder (added in the AI generator phase)
ANTHROPIC_API_KEY=""

# Transactional email (Resend) — verification, password reset, automation emails
RESEND_API_KEY=""
EMAIL_FROM="NovaCRM <onboarding@resend.dev>" # swap to your own verified domain before launch

# Used to build absolute URLs (Stripe redirects, robots.txt, sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
