generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (Auth.js / NextAuth Prisma adapter shape) + tenancy
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for OAuth-only users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum PlanTier {
  FREE
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// An Organization is a tenant: one customer's workspace, containing exactly
// the CRM(s) they've built. Every dynamic-engine row below is scoped to one.
model Organization {
  id         String  @id @default(cuid())
  name       String
  slug       String  @unique
  logoUrl    String?
  brandColor String? @default("#6366f1")

  plan                   PlanTier  @default(FREE)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // Invoicing — the tenant's own business details shown on their invoice
  // headers (separate from ValensCRM's own legal entity info).
  invoiceCounter  Int     @default(0) // atomically incremented for sequential invoice numbers
  businessAddress String?
  vatNumber       String?

  // Appointment booking
  appointmentDurationMinutes Int @default(60)
  bookingWindowDays          Int @default(14)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        Membership[]
  objects            CrmObject[]
  webhooks           Webhook[]
  auditLogs          AuditLog[]
  invoices           Invoice[]
  availabilityRules  AvailabilityRule[]
  availabilityBlocks AvailabilityBlock[]
  appointments       Appointment[]

  @@index([stripeCustomerId])
}

model Membership {
  id             String         @id @default(cuid())
  role           MembershipRole @default(OWNER)
  userId         String
  organizationId String
  createdAt      DateTime       @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Dynamic object engine
//
// Users don't get fixed "Contact" / "Company" tables — they build their own.
// So instead of one Postgres table per CRM concept (which would mean a schema
// migration every time a customer adds a table or field), every user-defined
// table is a row in CrmObject, every column is a row in CrmField, and every
// record's data lives as JSONB on CrmRecord keyed by field apiName. Postgres
// JSONB + GIN indexing keeps this queryable at scale without per-tenant DDL.
// Built-in templates (e.g. what the AI generator scaffolds) are just rows
// here like anything else — there is no special-cased "system" schema.
// ---------------------------------------------------------------------------

enum FieldType {
  TEXT
  LONG_TEXT
  NUMBER
  CURRENCY
  BOOLEAN
  DATE
  DATETIME
  EMAIL
  PHONE
  URL
  SELECT
  MULTI_SELECT
  USER_REF // reference to a Membership (e.g. "assigned to")
  RELATION // reference to record(s) in another CrmObject
  ATTACHMENT
  FORMULA
  AUTO_NUMBER
}

enum ViewType {
  TABLE
  KANBAN
  CALENDAR
  FORM
}

model CrmObject {
  id             String   @id @default(cuid())
  organizationId String
  name           String // display name, e.g. "Jobs"
  apiName        String // stable key, e.g. "jobs"
  icon           String?
  description    String?
  isSystem       Boolean  @default(false) // seeded by AI generator / template, still user-editable
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fields       CrmField[]
  records      CrmRecord[]
  views        CrmView[]
  automations  CrmAutomation[]

  @@unique([organizationId, apiName])
  @@index([organizationId])
}

model CrmField {
  id           String    @id @default(cuid())
  objectId     String
  name         String // display name, e.g. "Job Status"
  apiName      String // key inside CrmRecord.data, e.g. "job_status"
  type         FieldType
  options      Json? // e.g. select choices, relation target objectId, formula expression
  isRequired   Boolean   @default(false)
  defaultValue Json?
  position     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  object CrmObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@unique([objectId, apiName])
  @@index([objectId])
}

model CrmRecord {
  id             String   @id @default(cuid())
  objectId       String
  organizationId String // denormalized for fast tenant-wide queries/RLS
  data           Json // { [field.apiName]: value }
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  object CrmObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@index([objectId])
  @@index([organizationId])
}

model CrmView {
  id        String   @id @default(cuid())
  objectId  String
  name      String
  type      ViewType @default(TABLE)
  config    Json? // filters, sort, visible fields, group-by, kanban stage field, etc.
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  object CrmObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@index([objectId])
}

enum AutomationTrigger {
  RECORD_CREATED
  RECORD_UPDATED
}

// actions is an ordered array of { type: "SEND_EMAIL" | "CREATE_TASK" | "UPDATE_FIELD" | "ASSIGN_USER" | "SEND_REMINDER", config: {...} }
model CrmAutomation {
  id             String            @id @default(cuid())
  organizationId String
  objectId       String
  name           String
  isActive       Boolean           @default(true)
  trigger        AutomationTrigger
  conditions     Json? // optional [{ fieldApiName, operator, value }]
  actions        Json
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  object CrmObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@index([objectId])
  @@index([organizationId])
}

model Webhook {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  secret         String
  events         String[] // e.g. ["record.created", "record.updated"]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// action is a dotted event name, e.g. "organization.branding_updated", "billing.plan_changed"
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

// ---------------------------------------------------------------------------
// Invoicing
//
// Unlike the dynamic object engine above, invoices are first-class tables:
// they need decimal-precision money math, sequential legal numbering, and
// customer details snapshotted at issue time (so editing a linked Customer
// record later doesn't retroactively change an invoice that's already gone
// out). An invoice may optionally reference a CrmRecord (e.g. the Job or
// Customer it's for) as a soft link — not a hard foreign key, since that
// record could later be deleted without invalidating the invoice.
// ---------------------------------------------------------------------------

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  number         String // e.g. "INV-0001", sequential per org via Organization.invoiceCounter
  status         InvoiceStatus @default(DRAFT)

  // Snapshotted at issue time — not linked live to a CrmRecord.
  customerName    String
  customerEmail   String?
  customerAddress String?
  crmRecordId     String? // optional soft link to the Customer/Job record this is for

  subtotal  Decimal @db.Decimal(10, 2)
  vatAmount Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  notes    String?
  issuedAt DateTime?
  dueAt    DateTime?
  paidAt   DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lineItems    InvoiceLineItem[]

  @@unique([organizationId, number])
  @@index([organizationId])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  vatRate     Decimal @default(20) @db.Decimal(5, 2) // percentage, e.g. 20.00
  lineTotal   Decimal @db.Decimal(10, 2) // quantity * unitPrice, before VAT
  position    Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
// Appointment booking
//
// Also first-class: a public, unauthenticated booking flow needs a real
// DB-level guarantee against double-booking, which the JSONB dynamic-record
// engine can't provide on its own. Appointment slots are always aligned to
// Organization.appointmentDurationMinutes, so @@unique([organizationId,
// startsAt]) is sufficient to make a double-booking a clean constraint
// violation rather than a check-then-insert race condition.
// ---------------------------------------------------------------------------

model AvailabilityRule {
  id             String @id @default(cuid())
  organizationId String
  dayOfWeek      Int // 0 = Sunday .. 6 = Saturday
  startTime      String // "HH:mm", organization's local time
  endTime        String // "HH:mm"

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AvailabilityBlock {
  id             String   @id @default(cuid())
  organizationId String
  date           DateTime @db.Date
  reason         String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum AppointmentStatus {
  CONFIRMED
  CANCELLED
}

model Appointment {
  id             String            @id @default(cuid())
  organizationId String
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(CONFIRMED)

  customerName  String
  customerEmail String
  customerPhone String?
  notes         String?
  crmRecordId   String? // optional soft link to a Customer/Job record

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, startsAt])
  @@index([organizationId, startsAt])
}
